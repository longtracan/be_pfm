{
  "name": "backend-pfm",
  "version": "2.0.0",
  "description": "PFM backend — Cloudflare Workers + Hono + D1 + Durable Objects",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:remote": "wrangler dev --remote --env preview",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "db:migrate": "wrangler d1 migrations apply pfm_dts --remote",
    "db:migrate:preview": "wrangler d1 migrations apply pfm_dts_dev --remote --env preview",
    "db:migrate:local": "wrangler d1 migrations apply pfm_dts --local",
    "db:seed": "wrangler d1 execute pfm_dts --remote --file migrations/0002_seed.sql",
    "db:seed:preview": "wrangler d1 execute pfm_dts_dev --remote --env preview --file migrations/0002_seed.sql",
    "logs": "wrangler tail pfm-backend",
    "logs:errors": "wrangler tail pfm-backend --status error"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "hono": "^4.12.23",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "wrangler": "^3.114.0"
  }
}

        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const reqName = (pm.info.requestName || '').toLowerCase();",
          "const publicRequests = ['login', 'check db', 'root'];",
          "if (publicRequests.some((name) => reqName.includes(name))) {",
          "  return;",
          "}",
          "const token = pm.environment.get('token');",
          "if (token) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}"
        ]
      }
    }
  ],

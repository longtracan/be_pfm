    {
      "name": "Patients",
      "item": [
        {
          "name": "Upsert Patient (Auto Save IDs)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "if (data.patient && data.patient.id) {",
                  "  pm.environment.set('patient_id', data.patient.id);",
                  "}",
                  "if (data.patient && data.patient.patient_key) {",
                  "  pm.environment.set('patient_key', data.patient.patient_key);",
                  "}",
                  "if (data.queue && data.queue.queue_id) {",
                  "  pm.environment.set('queue_id', data.queue.queue_id);",
                  "  pm.environment.set('queue_number', String(data.queue.queue_number || ''));",
                  "}",
                  "",
                  "pm.test('patient_id is saved', function () {",
                  "  pm.expect(pm.environment.get('patient_id')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medical_code\": \"{{medical_code}}\",\n  \"identity_number\": \"{{identity_number}}\",\n  \"full_name\": \"{{patient_full_name}}\",\n  \"dob\": \"{{patient_dob}}\",\n  \"gender\": \"{{patient_gender}}\",\n  \"address\": \"{{patient_address}}\",\n  \"address_cv30\": \"{{patient_address_cv30}}\",\n  \"is_priority\": {{is_priority}},\n  \"is_online_booking\": {{is_online_booking}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/patients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patients"
              ]
            }
          }
        },
